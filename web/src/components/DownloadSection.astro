---
import { type SiteDictionary, type SupportedLocale } from '../i18n/site'

interface Props {
  locale: SupportedLocale
  t: SiteDictionary
}

const { t } = Astro.props
const checkSVG = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>'
const dashSVG = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="6" y1="12" x2="18" y2="12"/></svg>'
const appleSVG = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>'
const githubSVG = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>'
---

<section id="download">
  <div class="dl-container">

    <!-- Download Cards -->
    <div class="dl-cards">
      <div class="dl-card dl-card--pro">
        <div class="dl-card-glow" aria-hidden="true"></div>
        <div class="dl-card-content">
          <span class="dl-card-badge dl-card-badge--pro">{t.download.pro.badge}</span>
          <h3 class="dl-card-title">{t.download.pro.title}</h3>
          <p class="dl-card-desc">{t.download.pro.desc}</p>
          <a href={t.download.pro.url} class="btn-primary dl-btn" target="_blank" rel="noopener">
            <span set:html={appleSVG} />
            {t.download.pro.cta}
          </a>
        </div>
      </div>

      <div class="dl-card dl-card--oss">
        <div class="dl-card-content">
          <span class="dl-card-badge">{t.download.oss.badge}</span>
          <h3 class="dl-card-title">{t.download.oss.title}</h3>
          <p class="dl-card-desc">{t.download.oss.desc}</p>
          <a href={t.download.oss.url} class="btn-secondary dl-btn" target="_blank" rel="noopener">
            <span set:html={githubSVG} />
            {t.download.oss.cta}
          </a>
        </div>
      </div>
    </div>

    <!-- System Requirements -->
    <div class="dl-reqs">
      <span class="dl-reqs-label">System Requirements</span>
      <div class="dl-reqs-list">
        <span class="dl-reqs-item">macOS 14 (Sonoma) or later</span>
        <span class="dl-reqs-sep" aria-hidden="true"></span>
        <span class="dl-reqs-item">Apple Silicon or Intel</span>
        <span class="dl-reqs-sep" aria-hidden="true"></span>
        <span class="dl-reqs-item">6 GHz requires Wi-Fi 6E/7 hardware</span>
      </div>
    </div>

    <!-- Feature Comparison -->
    <div class="dl-compare">
      <h3 class="dl-compare-title">Feature Comparison</h3>
      <div class="cmp-grid">
        <div class="cmp-header">
          <span class="cmp-header-feature">Features</span>
          <span class="cmp-header-col cmp-header-col--oss">OSS</span>
          <span class="cmp-header-col cmp-header-col--pro">Pro</span>
        </div>
        {t.download.comparison.rows.map((row) => (
          <div class="cmp-row">
            <span class="cmp-feature-name">{row.feature}</span>
            <span class="cmp-cell cmp-cell--oss">
              {row.oss ? <span class="cmp-yes" set:html={checkSVG} /> : <span class="cmp-no" set:html={dashSVG} />}
            </span>
            <span class="cmp-cell cmp-cell--pro">
              {row.pro ? <span class="cmp-yes" set:html={checkSVG} /> : <span class="cmp-no" set:html={dashSVG} />}
            </span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  #download {
    padding: 0 2rem 4rem;
  }

  .dl-container {
    max-width: 820px;
    margin: 0 auto;
  }

  /* === Download Cards === */
  .dl-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .dl-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 20px;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
  }

  .dl-card:hover {
    transform: translateY(-3px);
  }

  .dl-card-content {
    position: relative;
    z-index: 1;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-sizing: border-box;
  }

  /* === Pro Card === */
  .dl-card--pro {
    border-color: rgba(76, 201, 200, 0.2);
  }

  .dl-card--pro:hover {
    border-color: rgba(76, 201, 200, 0.45);
  }

  .dl-card-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(76, 201, 200, 0.1), transparent 70%),
      linear-gradient(180deg, rgba(76, 201, 200, 0.04), transparent 60%);
    pointer-events: none;
  }

  /* === OSS Card === */
  .dl-card--oss {
    border-color: var(--border2);
  }

  .dl-card--oss:hover {
    border-color: rgba(255, 255, 255, 0.18);
  }

  /* === Badge === */
  .dl-card-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.7rem;
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.06);
    border-radius: 980px;
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
    width: fit-content;
  }

  .dl-card-badge--pro {
    color: var(--accent);
    background: var(--accent-dim);
  }

  .dl-card-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.625rem;
    line-height: 1.2;
  }

  .dl-card-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 1.25rem;
    flex: 1;
  }

  .dl-btn {
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
    gap: 0.5rem;
  }

  /* === System Requirements === */
  .dl-reqs {
    text-align: center;
    margin-bottom: 3rem;
    padding: 1rem 1.5rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    border-radius: 14px;
  }

  .dl-reqs-label {
    display: block;
    font-size: 0.625rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .dl-reqs-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.8125rem;
    color: var(--dim);
  }

  .dl-reqs-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--dim);
    opacity: 0.35;
    flex-shrink: 0;
  }

  /* === Feature Comparison Grid === */
  .dl-compare {
    margin-top: 0.5rem;
  }

  .dl-compare-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
    margin: 0 0 1.5rem;
  }

  .cmp-grid {
    border: 1px solid var(--border2);
    border-radius: 16px;
    overflow: hidden;
  }

  .cmp-header {
    display: grid;
    grid-template-columns: 1fr 56px 56px;
    align-items: center;
    padding: 0.875rem 1.25rem;
    background: var(--surface);
    border-bottom: 1px solid var(--border2);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .cmp-header-feature {
    color: var(--muted);
  }

  .cmp-header-col {
    text-align: center;
  }

  .cmp-header-col--pro {
    color: var(--accent);
  }

  .cmp-row {
    display: grid;
    grid-template-columns: 1fr 56px 56px;
    align-items: center;
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }

  .cmp-row:last-child {
    border-bottom: none;
  }

  .cmp-row:hover {
    background: rgba(255, 255, 255, 0.015);
  }

  .cmp-feature-name {
    font-size: 0.875rem;
    color: var(--fg);
    font-weight: 400;
  }

  .cmp-cell {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cmp-yes {
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .cmp-no {
    color: var(--dim);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0.35;
  }

  @media (max-width: 900px) {
    #download {
      padding: 0 1.5rem 4rem;
    }

    .dl-cards {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .dl-card-content {
      padding: 1.5rem;
    }
  }

  /* === Mobile === */
  @media (max-width: 640px) {
    #download {
      padding: 0 1.25rem 3rem;
    }

    .dl-card-content {
      padding: 1.25rem;
    }

    .dl-card-title {
      font-size: 1.25rem;
    }

    .dl-btn {
      width: 100%;
      box-sizing: border-box;
    }

    .dl-reqs {
      padding: 0.875rem 1rem;
    }

    .dl-reqs-list {
      flex-direction: column;
      gap: 0.25rem;
    }

    .dl-reqs-sep {
      display: none;
    }

    .cmp-grid {
      border: none;
      overflow: visible;
      display: grid;
      gap: 0.75rem;
      background: transparent;
    }

    .cmp-header {
      display: none;
    }

    .cmp-row {
      grid-template-columns: minmax(0, 1fr) 44px 44px;
      gap: 0.5rem;
      padding: 1rem;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.02);
    }

    .cmp-row:last-child {
      border-bottom: 1px solid var(--border);
    }

    .cmp-feature-name {
      font-size: 0.8125rem;
    }
  }
</style>
