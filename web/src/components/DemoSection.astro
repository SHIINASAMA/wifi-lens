---
import { Image } from 'astro:assets'
import { withBase, type SiteDictionary, type SupportedLocale } from '../i18n/site'
import { getScreenshot } from '../assets/images'

interface Props {
  locale: SupportedLocale
  t: SiteDictionary
}

const { t } = Astro.props
const checkSVG = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>'
---

<section id="demo-sec" class="sec-pad">
  <div class="sec-inner">
    <div class="demo-list-spacing">
      {t.demo.items.map((item, index) => (
        <div class="demo-row">
          {index % 2 === 0 ? (
            <>
              <div class="demo-img">
                <Image src={getScreenshot(item.image)} alt={item.alt} loading={index === 0 ? 'eager' : 'lazy'} decoding="async" widths={[800]} />
              </div>
              <div class="demo-text">
                <h3>{item.title}</h3>
                <p>{item.desc}</p>
                <ul>
                  {item.bullets.map((bullet) => (
                    <li><span set:html={checkSVG} />{bullet}</li>
                  ))}
                </ul>
              </div>
            </>
          ) : (
            <>
              <div class="demo-text">
                <h3>{item.title}</h3>
                <p>{item.desc}</p>
                <ul>
                  {item.bullets.map((bullet) => (
                    <li><span set:html={checkSVG} />{bullet}</li>
                  ))}
                </ul>
              </div>
              <div class="demo-img">
                <Image src={getScreenshot(item.image)} alt={item.alt} loading={index === 0 ? 'eager' : 'lazy'} decoding="async" widths={[800]} />
              </div>
            </>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .demo-list-spacing {
    margin-top: 2.5rem;
  }

  .demo-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  .demo-row + .demo-row {
    margin-top: 4rem;
  }

  .demo-img {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    box-shadow: 0 20px 60px -20px rgba(0, 0, 0, 0.5);
  }

  .demo-img :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  .demo-text h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.65rem;
  }

  .demo-text > p {
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 1.1rem;
  }

  .demo-text ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
  }

  .demo-text li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  @media (max-width: 768px) {
    .demo-row {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .demo-row + .demo-row {
      margin-top: 3rem;
    }

    .demo-img :global(img) {
      max-height: 260px;
      object-fit: contain;
    }
  }
</style>
