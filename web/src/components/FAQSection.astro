---
import { type SiteDictionary, type SupportedLocale } from '../i18n/site'

interface Props {
  locale: SupportedLocale
  t: SiteDictionary
  limit?: number
}

const { t, limit } = Astro.props
const faqItems = limit ? t.faq.items.slice(0, limit) : t.faq.items
---

<section class="sec-pad">
  <div class="sec-narrow">
    <div class="faq-grid">
      {faqItems.map((item) => (
        <details class="faq-item">
          <summary><span>{item.q}</span></summary>
          <div class="faq-answer"><p>{item.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-grid {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .faq-item {
    background: var(--surface);
    padding: 1.25rem 1.5rem;
  }

  .faq-item summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--muted);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0.75rem 0 0.25rem;
  }

  .faq-item p {
    font-size: 0.8125rem;
    color: var(--dim);
    line-height: 1.6;
  }

  @media (max-width: 560px) {
    .faq-item summary {
      font-size: 0.875rem;
    }
  }
</style>
