---
import { type SiteDictionary, type SupportedLocale } from '../i18n/site'

interface Props {
  locale: SupportedLocale
  t: SiteDictionary
}

const { t } = Astro.props

const endpoints = [
  {
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>',
    title: 'networks',
    desc: t.mcp.endpoints.networks,
  },
  {
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/></svg>',
    title: 'detail',
    desc: t.mcp.endpoints.detail,
  },
  {
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 3v18h18"/><rect x="7" y="10" width="3" height="8" rx="0.5"/><rect x="12" y="6" width="3" height="12" rx="0.5"/><rect x="17" y="8" width="3" height="10" rx="0.5"/></svg>',
    title: 'occupancy',
    desc: t.mcp.endpoints.occupancy,
  },
]
---

<section id="mcp" class="sec-pad">
  <div class="sec-inner">
    <div class="mcp-endpoints">
      <span class="sec-label">{t.mcp.endpoints.title}</span>
      <div class="mcp-ep-grid">
        {endpoints.map((ep) => (
          <div class="mcp-ep-card">
            <span class="mcp-ep-icon" set:html={ep.icon} />
            <h3>{ep.title}</h3>
            <p>{ep.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="mcp-config">
      <span class="sec-label">{t.mcp.config.title}</span>
      <p class="mcp-config-desc">{t.mcp.config.desc}</p>
      <div class="mcp-term">
        <div class="th">
          <span class="tf">claude_desktop_config.json</span>
          <span class="dots"><span class="dot"></span><span class="dot"></span><span class="dot"></span></span>
        </div>
        <pre>{`{
  "mcpServers": {
    "wifi-lens": {
      "command": "WiFiLensMCP",
      "args": ["19840"]
    }
  }
}`}</pre>
      </div>
    </div>

    <div class="mcp-cta-row">
      <a href="https://github.com/SHIINASAMA/wifi-lens/tree/master/docs" class="btn-secondary">{t.mcp.cta.docs}</a>
      <a href="https://github.com/SHIINASAMA/wifi-lens" class="btn-secondary">{t.mcp.cta.github}</a>
    </div>
  </div>
</section>

<style>
  .mcp-endpoints {
    margin-bottom: 3rem;
  }

  .mcp-ep-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .mcp-ep-card {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.2s;
  }

  .mcp-ep-card:hover {
    border-color: rgba(76, 201, 200, 0.25);
  }

  .mcp-ep-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--accent-dim);
    color: var(--accent);
    margin-bottom: 0.25rem;
  }

  .mcp-ep-card h3 {
    font-size: 0.9375rem;
    font-weight: 700;
    font-family: 'SF Mono', 'JetBrains Mono', ui-monospace, monospace;
    margin: 0;
    color: var(--fg);
  }

  .mcp-ep-card p {
    font-size: 0.8125rem;
    color: var(--dim);
    line-height: 1.6;
    margin: 0;
  }

  .mcp-config {
    margin-bottom: 2.5rem;
  }

  .mcp-config-desc {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.55;
    max-width: 36rem;
    margin: 1rem 0 0;
  }

  .mcp-term {
    max-width: 520px;
    margin: 2rem auto 0;
    background: #0d0d0f;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .mcp-term .th {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 1rem;
    background: #121214;
    border-bottom: 1px solid var(--border);
  }

  .mcp-term .dots {
    display: flex;
    gap: 6px;
  }

  .mcp-term .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
  }

  .mcp-term .tf {
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--dim);
  }

  .mcp-term pre {
    padding: 1.2rem 1.5rem;
    margin: 0;
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--muted);
    font-family: 'SF Mono', 'JetBrains Mono', ui-monospace, monospace;
  }

  .mcp-cta-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  @media (max-width: 768px) {
    .mcp-ep-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .mcp-term {
      margin-left: -1.25rem;
      margin-right: -1.25rem;
      border-radius: 0;
      border-left: none;
      border-right: none;
    }
  }
</style>
