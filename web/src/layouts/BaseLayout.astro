---
import Footer from '../components/Footer.astro'
import Header from '../components/Header.astro'
import { getAlternateLinks, getDictionary, withBase, type PageKey, type SupportedLocale } from '../i18n/site'
import '../styles/global.css'

interface Props {
  locale: SupportedLocale
  page: PageKey
  title: string
  description: string
  structuredData?: object | object[]
  ogImage?: string
}

const { locale, page, title, description, structuredData = [], ogImage } = Astro.props
const t = getDictionary(locale)
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const alternates = getAlternateLinks(page)
const jsonLd = Array.isArray(structuredData) ? structuredData : [structuredData]
const resolvedOgImage = ogImage
  ? new URL(withBase(ogImage), Astro.site).href
  : new URL(withBase('/screenshots/overview.png'), Astro.site).href
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="theme-color" content="#0a0a0c" />
    <meta name="google-site-verification" content="yy8KvFAAXhl7e4VcVqMr0XioH38oCpmVJTDa67wA9oY" />
    <meta name="msvalidate.01" content="B2028B0F09EF307A2DFD985F8381E22C" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="sitemap" type="application/xml" href={withBase('/sitemap-index.xml')} />
    {alternates.map((alternate) => (
      <link rel="alternate" hrefLang={alternate.hrefLang} href={new URL(alternate.href, Astro.site).href} />
    ))}
    <link rel="alternate" hrefLang="x-default" href={new URL(alternates[0].href, Astro.site).href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase('/apple-touch-icon.png')} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase('/favicon-32x32.png')} />
    <link rel="icon" type="image/png" sizes="16x16" href={withBase('/favicon-16x16.png')} />
    <link rel="icon" type="image/ico" href={withBase('/favicon.ico')} />
    <link rel="manifest" href={withBase('/site.webmanifest')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:alt" content="WiFi Lens overview screenshot" />
    <meta property="og:site_name" content="WiFi Lens" />
    <meta name="author" content="WiFi Lens" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:site" content="@WiFiLens" />
    {jsonLd.filter(Boolean).map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body>
    <div class="page">
      <a id="skip-link" href="#main-content">{t.a11y.skipLink}</a>
      <Header locale={locale} page={page} t={t} />
      <main id="main-content">
        <slot />
      </main>
      <Footer t={t} locale={locale} page={page} />
      <button id="btt" aria-label={t.a11y.backToTop} type="button">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="18 15 12 9 6 15"></polyline>
        </svg>
      </button>
    </div>
    <script is:inline>
      const nav = document.getElementById('nav')
      const toggle = nav?.querySelector('[data-menu-toggle]')
      const panel = nav?.querySelector('[data-menu-panel]')
      const closeButton = nav?.querySelector('[data-menu-close]')
      let trapFocus = null

      const closeMenu = () => {
        nav?.classList.remove('mobile-open')
        toggle?.classList.remove('open')
        toggle?.setAttribute('aria-expanded', 'false')
        document.body.classList.remove('menu-open')
        if (trapFocus) {
          nav?.removeEventListener('keydown', trapFocus)
          trapFocus = null
        }
      }

      toggle?.addEventListener('click', () => {
        const open = nav.classList.toggle('mobile-open')
        toggle.classList.toggle('open', open)
        toggle.setAttribute('aria-expanded', String(open))
        document.body.classList.toggle('menu-open', open)
        if (open) {
          trapFocus = function (e) {
            if (e.key === 'Escape') {
              closeMenu()
              toggle?.focus()
              return
            }
            if (e.key !== 'Tab') return
            const focusable = nav?.querySelectorAll('a, button, [tabindex]:not([tabindex="-1"])') || []
            const first = focusable[0]
            const last = focusable[focusable.length - 1]
            if (e.shiftKey && document.activeElement === first) {
              e.preventDefault()
              last?.focus()
            } else if (!e.shiftKey && document.activeElement === last) {
              e.preventDefault()
              first?.focus()
            }
          }
          nav?.addEventListener('keydown', trapFocus)
        } else {
          closeMenu()
        }
      })

      closeButton?.addEventListener('click', () => {
        closeMenu()
        toggle?.focus()
      })

      panel?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          closeMenu()
        })
      })

      let scrollTicking = false
      window.addEventListener('scroll', () => {
        if (scrollTicking) return
        scrollTicking = true
        requestAnimationFrame(() => {
          nav?.classList.toggle('scrolled', window.scrollY > 20)
          document.getElementById('btt')?.classList.toggle('visible', window.scrollY > 500)
          scrollTicking = false
        })
      }, { passive: true })

      document.getElementById('btt')?.addEventListener('click', () => {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
        window.scrollTo({ top: 0, behavior: prefersReduced ? 'auto' : 'smooth' })
      })
    </script>
  </body>
</html>

<style>
  #skip-link {
    position: fixed;
    top: -100%;
    left: 1rem;
    z-index: 200;
    padding: 0.75rem 1.5rem;
    background: var(--accent);
    color: #0a0a0c;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    transition: top 0.2s;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  #skip-link:focus {
    top: 0.75rem;
  }

  .page {
    overflow-x: hidden;
  }

  #btt {
    position: fixed;
    bottom: calc(1.5rem + env(safe-area-inset-bottom, 0px));
    right: calc(1.5rem + env(safe-area-inset-right, 0px));
    z-index: 90;
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 50%;
    color: var(--muted);
    opacity: 0;
    pointer-events: none;
  }

  #btt.visible {
    opacity: 1;
    pointer-events: auto;
  }
</style>
