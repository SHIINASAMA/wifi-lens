---
import FAQSection from '../../components/FAQSection.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getDictionary, getPagePath, isSupportedLocale, localeOrder } from '../../i18n/site'

export function getStaticPaths() {
  return localeOrder.filter((locale) => locale !== 'en').map((locale) => ({ params: { locale } }))
}

const localeParam = Astro.params.locale
if (!localeParam || !isSupportedLocale(localeParam) || localeParam === 'en') {
  throw new Error('Invalid locale route')
}

const locale = localeParam
const t = getDictionary(locale)
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: t.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<BaseLayout locale={locale} page="faq" title={`${t.faq.title} | WiFi Lens`} description={t.faq.metaDescription} structuredData={[faqJsonLd]}>
  <section class="page-intro">
    <span class="sec-label">{t.nav.faq}</span>
    <h1 class="sec-title">{t.faq.title}</h1>
  </section>
  <FAQSection locale={locale} t={t} />
  <section class="page-cta">
    <div class="sec-inner">
      <span class="page-cta-label">{t.home.exploreLabel}</span>
      <h2 class="page-cta-title">{t.home.exploreTitle}</h2>
      <div class="page-cta-grid">
        <a href={getPagePath(locale, 'privacy')} class="page-cta-card">
          <span class="card-label">{t.nav.privacy}</span>
          <h3>{t.privacy.title}</h3>
          <p class="card-desc">{t.privacy.subtitle}</p>
          <span class="card-arrow">{t.home.viewPage}</span>
        </a>
        <a href={getPagePath(locale, 'download')} class="page-cta-card">
          <span class="card-label">{t.nav.download}</span>
          <h3>{t.download.title}</h3>
          <p class="card-desc">{t.download.oss.desc}</p>
          <span class="card-arrow">{t.home.viewPage}</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
