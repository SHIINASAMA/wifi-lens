---
import DownloadSection from '../../components/DownloadSection.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getDictionary, getPagePath, isSupportedLocale, localeOrder } from '../../i18n/site'

export function getStaticPaths() {
  return localeOrder.filter((locale) => locale !== 'en').map((locale) => ({ params: { locale } }))
}

const localeParam = Astro.params.locale
if (!localeParam || !isSupportedLocale(localeParam) || localeParam === 'en') {
  throw new Error('Invalid locale route')
}

const locale = localeParam
const t = getDictionary(locale)
const downloadJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${t.download.title} | WiFi Lens`,
  description: t.download.oss.desc,
  about: {
    '@type': 'SoftwareApplication',
    name: 'WiFi Lens',
    operatingSystem: 'macOS 14+',
    applicationCategory: 'UtilitiesApplication',
  },
  hasPart: [
    {
      '@type': 'SoftwareApplication',
      name: t.download.oss.title,
      description: t.download.oss.desc,
      operatingSystem: 'macOS 14+',
      applicationCategory: 'UtilitiesApplication',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      downloadUrl: t.download.oss.url,
    },
    {
      '@type': 'SoftwareApplication',
      name: t.download.pro.title,
      description: t.download.pro.desc,
      operatingSystem: 'macOS 14+',
      applicationCategory: 'UtilitiesApplication',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      downloadUrl: t.download.pro.url,
    },
  ],
}
---

<BaseLayout locale={locale} page="download" title={`${t.download.title} | WiFi Lens`} description={t.download.metaDescription} structuredData={[downloadJsonLd]}>
  <section class="dl-hero">
    <div class="dl-wave-arcs" aria-hidden="true">
      <svg viewBox="0 0 800 400" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M400 400 A200 200 0 0 1 200 200" stroke="url(#wave-grad-1)" stroke-width="1.5" opacity="0.12"/>
        <path d="M400 400 A240 240 0 0 1 160 160" stroke="url(#wave-grad-1)" stroke-width="1.2" opacity="0.09"/>
        <path d="M400 400 A280 280 0 0 1 120 120" stroke="url(#wave-grad-2)" stroke-width="1" opacity="0.07"/>
        <path d="M400 400 A320 320 0 0 1 80 80" stroke="url(#wave-grad-2)" stroke-width="0.8" opacity="0.05"/>
        <path d="M400 400 A200 200 0 0 0 600 200" stroke="url(#wave-grad-1)" stroke-width="1.5" opacity="0.12"/>
        <path d="M400 400 A240 240 0 0 0 640 160" stroke="url(#wave-grad-1)" stroke-width="1.2" opacity="0.09"/>
        <path d="M400 400 A280 280 0 0 0 680 120" stroke="url(#wave-grad-2)" stroke-width="1" opacity="0.07"/>
        <path d="M400 400 A320 320 0 0 0 720 80" stroke="url(#wave-grad-2)" stroke-width="0.8" opacity="0.05"/>
        <circle cx="400" cy="400" r="3" fill="#4cc9c8" opacity="0.3"/>
        <circle cx="400" cy="400" r="6" fill="none" stroke="#4cc9c8" stroke-width="1" opacity="0.15"/>
        <defs>
          <linearGradient id="wave-grad-1" x1="200" y1="400" x2="400" y2="200" gradientUnits="userSpaceOnUse">
            <stop stop-color="#4cc9c8"/>
            <stop offset="1" stop-color="#4cc9c8" stop-opacity="0"/>
          </linearGradient>
          <linearGradient id="wave-grad-2" x1="200" y1="400" x2="400" y2="200" gradientUnits="userSpaceOnUse">
            <stop stop-color="#5ad7c3"/>
            <stop offset="1" stop-color="#5ad7c3" stop-opacity="0"/>
          </linearGradient>
        </defs>
      </svg>
    </div>
    <div class="dl-hero-inner">
      <span class="dl-hero-label">{t.nav.download}</span>
      <h1 class="dl-hero-title">{t.download.title}</h1>
      <p class="dl-hero-sub">{t.download.subtitle}</p>
    </div>
  </section>
  <DownloadSection locale={locale} t={t} />
  <section class="page-cta">
    <div class="sec-inner">
      <span class="page-cta-label">{t.home.exploreLabel}</span>
      <h2 class="page-cta-title">{t.home.exploreTitle}</h2>
      <div class="page-cta-grid">
        <a href={getPagePath(locale, 'features')} class="page-cta-card">
          <span class="card-label">{t.nav.features}</span>
          <h3>{t.features.title}</h3>
          <p class="card-desc">{t.demo.subtitle}</p>
          <span class="card-arrow">{t.home.viewPage}</span>
        </a>
        <a href={getPagePath(locale, 'faq')} class="page-cta-card">
          <span class="card-label">{t.nav.faq}</span>
          <h3>{t.faq.title}</h3>
          <p class="card-desc">{t.faq.items[0].a}</p>
          <span class="card-arrow">{t.home.viewPage}</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* === Download Hero === */
  .dl-hero {
    position: relative;
    padding: 6rem 2rem 3rem;
    text-align: center;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 420px;
  }

  .dl-wave-arcs {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    overflow: hidden;
  }

  .dl-wave-arcs svg {
    width: 100%;
    max-width: 800px;
    height: auto;
    opacity: 1;
  }

  .dl-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 640px;
  }

  .dl-hero-label {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .dl-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
  }

  .dl-hero-sub {
    font-size: 1.0625rem;
    color: var(--muted);
    line-height: 1.55;
    margin: 0 auto;
    max-width: 30rem;
  }

  @media (max-width: 640px) {
    .dl-hero {
      padding: 5rem 1.25rem 2rem;
      min-height: 320px;
    }

    .dl-wave-arcs svg {
      max-width: 500px;
    }
  }
</style>
