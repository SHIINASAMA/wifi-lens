---
import PrivacySection from '../../components/PrivacySection.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getDictionary, getPagePath, isSupportedLocale, localeOrder } from '../../i18n/site'

export function getStaticPaths() {
  return localeOrder.filter((locale) => locale !== 'en').map((locale) => ({ params: { locale } }))
}

const localeParam = Astro.params.locale
if (!localeParam || !isSupportedLocale(localeParam) || localeParam === 'en') {
  throw new Error('Invalid locale route')
}

const locale = localeParam
const t = getDictionary(locale)
const privacyJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${t.privacy.title} | WiFi Lens`,
  description: t.privacy.subtitle,
  lastReviewed: '2026-07-04',
  about: {
    '@type': 'SoftwareApplication',
    name: 'WiFi Lens',
    operatingSystem: 'macOS 14+',
    applicationCategory: 'UtilitiesApplication',
  },
}
---

<BaseLayout locale={locale} page="privacy" title={`${t.privacy.title} | WiFi Lens`} description={t.privacy.subtitle} structuredData={[privacyJsonLd]}>
  <section class="page-intro">
    <span class="sec-label">{t.nav.privacy}</span>
    <h1 class="sec-title">{t.privacy.title}</h1>
    <p class="sec-sub">{t.privacy.subtitle}</p>
  </section>
  <PrivacySection locale={locale} t={t} full />
  <section class="page-cta">
    <div class="sec-inner">
      <span class="page-cta-label">{t.home.exploreLabel}</span>
      <h2 class="page-cta-title">{t.home.exploreTitle}</h2>
      <div class="page-cta-grid">
        <a href={getPagePath(locale, 'features')} class="page-cta-card">
          <span class="card-label">{t.nav.features}</span>
          <h3>{t.features.title}</h3>
          <p class="card-desc">{t.demo.subtitle}</p>
          <span class="card-arrow">{t.home.viewPage}</span>
        </a>
        <a href={getPagePath(locale, 'download')} class="page-cta-card">
          <span class="card-label">{t.nav.download}</span>
          <h3>{t.download.title}</h3>
          <p class="card-desc">{t.download.oss.desc}</p>
          <span class="card-arrow">{t.home.viewPage}</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
