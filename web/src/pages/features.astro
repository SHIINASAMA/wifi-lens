---
import DemoSection from '../components/DemoSection.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { defaultLocale, getDictionary, getPagePath } from '../i18n/site'

const locale = defaultLocale
const t = getDictionary(locale)
const featuresJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${t.features.title} | WiFi Lens`,
  description: t.features.overview.desc,
  about: {
    '@type': 'SoftwareApplication',
    name: 'WiFi Lens',
    operatingSystem: 'macOS 14+',
    applicationCategory: 'UtilitiesApplication',
  },
  hasPart: [
    { '@type': 'WebPageElement', name: t.features.scanning.title, description: t.features.scanning.desc },
    { '@type': 'WebPageElement', name: t.features.table.title, description: t.features.table.desc },
    { '@type': 'WebPageElement', name: t.features.roaming.title, description: t.features.roaming.desc },
  ],
}
---

<BaseLayout locale={locale} page="features" title={`${t.features.title} | WiFi Lens`} description={t.features.overview.desc} structuredData={[featuresJsonLd]}>
  <section class="page-intro">
    <span class="sec-label">{t.nav.features}</span>
    <h1 class="sec-title">{t.features.title}</h1>
    <p class="sec-sub">{t.demo.subtitle}</p>
  </section>
  <DemoSection locale={locale} t={t} />
  <section class="page-cta">
    <div class="sec-inner">
      <span class="page-cta-label">{t.home.exploreLabel}</span>
      <h2 class="page-cta-title">{t.home.exploreTitle}</h2>
      <div class="page-cta-grid">
        <a href={getPagePath(locale, 'download')} class="page-cta-card">
          <span class="card-label">{t.nav.download}</span>
          <h3>{t.download.title}</h3>
          <p class="card-desc">{t.download.oss.desc}</p>
          <span class="card-arrow">{t.home.viewPage}</span>
        </a>
        <a href={getPagePath(locale, 'mcp')} class="page-cta-card">
          <span class="card-label">{t.nav.mcp}</span>
          <h3>{t.mcp.title}</h3>
          <p class="card-desc">{t.mcp.subtitle}</p>
          <span class="card-arrow">{t.home.viewPage}</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
