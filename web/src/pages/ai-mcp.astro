---
import MCPSection from '../components/MCPSection.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { defaultLocale, getDictionary, getPagePath } from '../i18n/site'

const locale = defaultLocale
const t = getDictionary(locale)
const mcpJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${t.mcp.title} | WiFi Lens`,
  description: t.mcp.subtitle,
  about: {
    '@type': 'SoftwareApplication',
    name: 'WiFi Lens',
    operatingSystem: 'macOS 14+',
    applicationCategory: 'UtilitiesApplication',
  },
  mainEntity: {
    '@type': 'SoftwareSourceCode',
    name: 'WiFi Lens MCP Server',
    description: 'MCP server for AI tool integration with Wi-Fi analysis data',
    programmingLanguage: 'JSON',
    runtimePlatform: 'macOS',
  },
}
---

<BaseLayout locale={locale} page="mcp" title={`${t.mcp.title} | WiFi Lens`} description={t.mcp.metaDescription} structuredData={[mcpJsonLd]}>
  <section class="page-intro">
    <span class="sec-label">{t.nav.mcp}</span>
    <h1 class="sec-title">{t.mcp.title}</h1>
    <p class="sec-sub">{t.mcp.subtitle}</p>
  </section>
  <MCPSection locale={locale} t={t} />
  <section class="page-cta">
    <div class="sec-inner">
      <span class="page-cta-label">{t.home.exploreLabel}</span>
      <h2 class="page-cta-title">{t.home.exploreTitle}</h2>
      <div class="page-cta-grid">
        <a href={getPagePath(locale, 'features')} class="page-cta-card">
          <span class="card-label">{t.nav.features}</span>
          <h3>{t.features.title}</h3>
          <p class="card-desc">{t.demo.subtitle}</p>
          <span class="card-arrow">{t.home.viewPage}</span>
        </a>
        <a href={getPagePath(locale, 'download')} class="page-cta-card">
          <span class="card-label">{t.nav.download}</span>
          <h3>{t.download.title}</h3>
          <p class="card-desc">{t.download.oss.desc}</p>
          <span class="card-arrow">{t.home.viewPage}</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
