---
const redirectUrl = 'https://wifi-lens.shiinalabs.com'
const title = 'WiFi Lens — Moved to wifi-lens.shiinalabs.com'
const description = 'WiFi Lens has moved to a new home. Visit wifi-lens.shiinalabs.com for the latest version.'
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0a0c" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <meta name="google-site-verification" content="yy8KvFAAXhl7e4VcVqMr0XioH38oCpmVJTDa67wA9oY" />
    <meta name="msvalidate.01" content="B2028B0F09EF307A2DFD985F8381E22C" />
    <link rel="canonical" href={redirectUrl} />
    <link rel="apple-touch-icon" sizes="180x180" href="/wifi-lens/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/wifi-lens/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/wifi-lens/favicon-16x16.png" />
    <link rel="icon" type="image/ico" href="/wifi-lens/favicon.ico" />
    <link rel="manifest" href="/wifi-lens/site.webmanifest" />

    <style>
      :root {
        --bg: #0a0a0c;
        --fg: #f5f5f7;
        --muted: #98989d;
        --accent: #4cc9c8;
        --border: rgba(255, 255, 255, 0.08);
      }

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        min-height: 100svh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg);
        color: var(--fg);
        font: 400 15px/1.6 -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
        padding: 2rem;
      }

      .container {
        max-width: 520px;
        text-align: center;
      }

      .logo {
        width: 72px;
        height: 72px;
        margin: 0 auto 2rem;
        border-radius: 16px;
      }

      h1 {
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', system-ui, sans-serif;
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.15;
        margin-bottom: 0.75rem;
      }

      p {
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: 2rem;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.75rem 1.75rem;
        font-size: 0.9375rem;
        font-weight: 600;
        border-radius: 980px;
        text-decoration: none;
        transition: background 0.2s, transform 0.2s;
        min-height: 44px;
      }

      .btn-primary {
        background: var(--accent);
        color: var(--bg);
      }

      .btn-primary:hover {
        background: #5dd4d3;
        transform: translateY(-1px);
      }

      .btn-secondary {
        margin-top: 0.75rem;
        color: var(--muted);
        font-size: 0.8125rem;
        font-weight: 500;
      }

      .btn-secondary:hover {
        color: var(--fg);
      }

      .arrow {
        transition: transform 0.2s;
      }

      .btn:hover .arrow {
        transform: translateX(2px);
      }

      .hint {
        margin-top: 2.5rem;
        font-size: 0.75rem;
        color: rgba(152, 152, 157, 0.5);
        letter-spacing: 0.02em;
      }

      @media (prefers-reduced-motion: reduce) {
        .btn { transition: none; }
        .btn:hover .arrow { transform: none; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <img class="logo" src="/wifi-lens/apple-touch-icon.png" alt="WiFi Lens icon" width="72" height="72" />
      <h1>WiFi Lens has moved</h1>
      <p>The WiFi Lens website has moved to a new home. Please visit the new site for the latest updates.</p>
      <a href={redirectUrl} class="btn btn-primary">
        Go to wifi-lens.shiinalabs.com
        <span class="arrow">&rarr;</span>
      </a>
      <a href={redirectUrl} class="btn btn-secondary">wifi-lens.shiinalabs.com</a>
      <p class="hint">Bookmark the new address for future visits.</p>
    </div>
  </body>
</html>
