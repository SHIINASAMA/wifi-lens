          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf Play, um den BLE-Scan zu starten"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca reproducir para iniciar el escaneo de dispositivos BLE"
          }
        }
      }
    },
