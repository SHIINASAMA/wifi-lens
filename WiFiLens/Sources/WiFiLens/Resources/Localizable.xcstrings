      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将当前 Wi-Fi 扫描数据暴露为本地 HTTP API，供 AI 工具（Claude Desktop 等）通过 MCP 查询。"
