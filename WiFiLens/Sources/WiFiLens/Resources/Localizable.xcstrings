      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Starting a new recording will discard the current session data. Save before continuing if you want to keep it."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しい録画を開始すると、現在のセッションデータは破棄されます。保存する場合は先に保存してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
