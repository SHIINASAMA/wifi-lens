    "ble.state.bluetooth_perm_required_desc": {
      "comment": "Detailed instructions to grant Bluetooth permission",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant Bluetooth permission in Settings → Permissions to scan for nearby BLE devices."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定 → 権限 で Bluetooth 権限を許可して、近くの BLE デバイスをスキャンしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在设置 → 权限中授予蓝牙权限以扫描附近的 BLE 设备。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erteile Bluetooth-Berechtigung in Einstellungen → Berechtigungen, um BLE-Geräte in der Nähe zu scannen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Concede permiso de Bluetooth en Ajustes → Permisos para escanear dispositivos BLE cercanos."
          }
        }
