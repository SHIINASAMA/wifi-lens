    "ble.state.bluetooth_off_desc": {
      "comment": "Instructions to enable Bluetooth",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Bluetooth in System Settings to scan for BLE devices."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "BLE デバイスをスキャンするには、システム設定で Bluetooth を有効にしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在系统设置中启用蓝牙以扫描 BLE 设备。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiviere Bluetooth in den Systemeinstellungen, um BLE-Geräte zu scannen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Habilita Bluetooth en Ajustes del Sistema para escanear dispositivos BLE."
          }
        }
