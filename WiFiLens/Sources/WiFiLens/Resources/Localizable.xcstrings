    "settings.permissions.bluetooth_desc": {
      "comment": "Description of why Bluetooth is needed",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only requested when Bluetooth Analysis is enabled. Allows discovering nearby BLE devices and analyzing their signal strength."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Bluetooth分析の有効時のみ要求されます。近隣のBLEデバイスの検出と信号強度の分析を可能にします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在开启蓝牙分析时请求。用于发现附近的 BLE 设备并分析其信号强度。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wird nur angefordert, wenn Bluetooth-Analyse aktiviert ist. Ermöglicht das Entdecken von BLE-Geräten in der Nähe und die Analyse ihrer Signalstärke."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo se solicita cuando el Análisis Bluetooth está habilitado. Permite descubrir dispositivos BLE cercanos y analizar su intensidad de señal."
          }
        }
      }
    },
    "settings.permissions.bluetooth_disabled_desc": {
      "comment": "Description when Bluetooth permission is unavailable because BLE is disabled",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Bluetooth Analysis to manage this permission."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この権限を管理するには、Bluetooth分析を有効にしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启蓝牙分析功能后可管理此权限。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiviere Bluetooth-Analyse, um diese Berechtigung zu verwalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Habilita Análisis Bluetooth para gestionar este permiso."
          }
        }
      }
    },
