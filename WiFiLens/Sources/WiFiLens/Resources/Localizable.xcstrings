    "settings.region.description": {
      "comment": "Description of how regional regulation filtering works",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Channel recommendations are filtered by regional regulations. Auto-detect uses system locale, hardware capabilities, and nearby AP information."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チャンネル推奨は地域規制に基づいてフィルタリングされます。自動検出では、システムロケール、ハードウェア能力、近隣AP情報を使用します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "信道推荐经过地区法规过滤。自动检测使用系统区域、硬件能力及附近 AP 信息。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kanalempfehlungen werden nach regionalen Vorschriften gefiltert. Die automatische Erkennung verwendet System-Locale, Hardware-Fähigkeiten und Informationen naher APs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las recomendaciones de canal se filtran por regulaciones regionales. La detección automática usa el locale del sistema, las capacidades de hardware y la información de APs cercanos."
          }
        }
      }
    },
