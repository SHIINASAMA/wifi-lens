    "settings.permissions.location_desc": {
      "comment": "Description of why Location Services is needed",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "WiFi Lens uses Location Services to read Wi-Fi network names (SSIDs). When denied, network names appear as \"n/a\", but signal strength and channel data remain fully available."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "WiFi LensはWi-Fiネットワーク名（SSID）の取得に位置情報サービスを使用します。許可しない場合、ネットワーク名は「n/a」と表示されますが、電波強度やチャンネルデータは引き続き利用可能です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "WiFi Lens 使用位置服务来读取 Wi-Fi 网络名称（SSID）。如果被拒绝，网络名称将显示为 \"n/a\"，但信号强度和信道数据仍然完全可用。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "WiFi Lens verwendet Ortungsdienste, um Wi‑Fi-Netzwerknamen (SSIDs) zu lesen. Wenn verweigert, erscheinen Netzwerknamen als \"n/a\", aber Signalstärke- und Kanaldaten bleiben vollständig verfügbar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "WiFi Lens usa Servicios de Ubicación para leer nombres de red Wi‑Fi (SSIDs). Cuando se deniega, los nombres de red aparecen como \"n/a\", pero los datos de intensidad de señal y canal permanecen completamente disponibles."
          }
        }
      }
    },
