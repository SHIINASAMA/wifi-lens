    "settings.diagnostics.logs_description": {
      "comment": "Explanation that logs are stored locally, never collected, and under user control",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Diagnostic logs are stored locally on your device. WiFi Lens never collects, uploads, or shares them. You are free to review, share, or delete these logs at any time."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "診断ログはお使いのデバイスにのみ保存されます。WiFi Lensがこれらを収集・アップロード・共有することは一切ありません。ログの確認、共有、削除はいつでも自由に行えます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "诊断日志仅存储在您的设备本地。WiFi Lens 不会收集、上传或分享这些日志。您可以随时自由查看、分享或删除它们。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diagnoseprotokolle werden lokal auf deinem Gerät gespeichert. WiFi Lens sammelt, lädt oder teilt sie niemals. Du kannst diese Protokolle jederzeit einsehen, teilen oder löschen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los registros de diagnóstico se almacenan localmente en tu dispositivo. WiFi Lens nunca los recopila, sube o comparte. Puedes revisar, compartir o eliminar estos registros en cualquier momento."
          }
        }
      }
    },
    "settings.features.ble_description": {
      "comment": "Description of Bluetooth analysis feature",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan for nearby Bluetooth devices and analyze signal strength and activity patterns. Disabled by default."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "近隣のBluetoothデバイスをスキャンし、信号強度とアクティビティパターンを分析します。デフォルトでは無効です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "扫描附近的蓝牙设备，分析信号强度和活动模式。默认关闭。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Scanne Bluetooth-Geräte in der Nähe und analysiere Signalstärke und Aktivitätsmuster. Standardmäßig deaktiviert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escanear dispositivos Bluetooth cercanos y analizar la intensidad de señal y patrones de actividad. Deshabilitado por defecto."
          }
        }
      }
    },
