    "ble.disabled.description" : {
      "comment" : "Description prompting user to enable BLE in settings",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiviere Bluetooth-Analyse in den Einstellungen, um Geräte in der Nähe zu scannen und die Signalstärke zu überwachen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable Bluetooth Analysis in Settings to scan for nearby devices and monitor signal strength."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Habilita Análisis Bluetooth en Ajustes para escanear dispositivos cercanos y monitorizar la intensidad de señal."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定で「Bluetooth分析」を有効にすると、近くのデバイスをスキャンし信号強度を監視できます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在设置中开启蓝牙分析后，可扫描附近设备并监测信号强度。"
          }
        }
      }
    },
