    "settings.mcp.description" : {
      "comment" : "Description of the MCP server feature",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktuelle Wi‑Fi-Scandaten als lokale HTTP-API für KI-Tools (Claude Desktop usw.) über MCP bereitstellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expose current Wi-Fi scan data as a local HTTP API for AI tools (Claude Desktop, etc.) to query via MCP."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exponer datos actuales de escaneo Wi‑Fi como una API HTTP local para que herramientas de IA (Claude Desktop, etc.) consulten vía MCP."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在の Wi-Fi スキャンデータをローカル HTTP API として公開し、AI ツール（Claude Desktop など）が MCP 経由でクエリできるようにします。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将当前 Wi-Fi 扫描数据暴露为本地 HTTP API，供 AI 工具（Claude Desktop 等）通过 MCP 查询。"
          }
        }
      }
    },
