    "roaming.warning.not_portable": {
      "comment": "Warning that roaming test needs a laptop, not desktop Mac",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This feature is designed for battery-equipped Mac laptops. Desktop Macs cannot simulate mobile roaming scenarios."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この機能はバッテリー搭載の Mac ノートパソコン向けです。デスクトップ Mac ではモバイルローミングのシミュレーションはできません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此功能适用于配备电池的 Mac 笔记本电脑，桌面 Mac 无法模拟移动漫游场景。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Funktion ist für Mac-Laptops mit Akku ausgelegt. Desktop-Macs können keine mobilen Roaming-Szenarien simulieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta función está diseñada para portátiles Mac con batería. Los Mac de escritorio no pueden simular escenarios de roaming móvil."
          }
        }
      }
    },
