        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前信道有些拥挤。切换信道可能改善网络体验。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チャンネルがやや混雑しています。切り替えるとパフォーマンスが向上する可能性があります。"
          }
        }
      }
    },
