    "ble.banner.interference" : {
      "comment" : "Info banner about BLE and 2.4 GHz Wi-Fi interference",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bluetooth arbeitet im 2,4-GHz-Band – viele BLE-Geräte können 2,4-GHz-WLANs stören und umgekehrt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bluetooth operates in the 2.4 GHz band — dense BLE activity can interfere with 2.4 GHz Wi-Fi networks and nearby Bluetooth devices."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bluetooth opera en la banda de 2,4 GHz: una alta densidad de dispositivos BLE puede interferir con redes Wi-Fi de 2,4 GHz y con otros dispositivos Bluetooth cercanos."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bluetoothは2.4GHz帯で動作します。密集したBLE環境では2.4GHz Wi-Fiネットワークや近隣のBluetoothデバイスに干渉する可能性があります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "蓝牙运行于 2.4 GHz 频段，密集的 BLE 设备可能干扰 2.4 GHz Wi-Fi 网络及附近的蓝牙设备。"
          }
        }
      }
    },
