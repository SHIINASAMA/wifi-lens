    "ble.accessibility.trend_chart_fmt": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "BLE RSSI trend chart, %1$d samples, range %2$d to %3$d dBm"
