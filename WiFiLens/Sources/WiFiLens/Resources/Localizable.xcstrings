    "You could improve by moving closer to the router or switching channels.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "You could improve by moving closer to the router or switching channels."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "靠近路由器或切换信道可以改善网络体验。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルーターに近づくか、チャンネルを切り替えることで改善できます。"
          }
        }
      }
    },
    "You're far from the router. Moving closer or adding a mesh node would help.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "You're far from the router. Moving closer or adding a mesh node would help."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你离路由器太远。靠近路由器或添加 Mesh 节点会有帮助。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルーターから遠く離れています。近づくか、メッシュノードを追加すると改善されます。"
          }
        }
      }
    },
    "You're on Wi‑Fi %@. Wi‑Fi 6 or 7 would give you faster speeds.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "You're on Wi‑Fi %@. Wi‑Fi 6 or 7 would give you faster speeds."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你正在使用 Wi‑Fi %@。Wi‑Fi 6 或 7 能给你更快的速度。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi‑Fi %@ を使用中です。Wi‑Fi 6 または 7 にするとより高速になります。"
          }
        }
      }
    },
    "Your channel has some congestion. Switching could improve performance.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Your channel has some congestion. Switching could improve performance."
