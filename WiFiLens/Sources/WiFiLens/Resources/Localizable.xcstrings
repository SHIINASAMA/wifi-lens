          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Starten einer neuen Aufnahme verwirft die aktuellen Sitzungsdaten. Speichere vor dem Fortfahren, wenn du sie behalten möchtest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar una nueva grabación descartará los datos de la sesión actual. Guarda antes de continuar si quieres conservarlos."
          }
