    "ble.permission.denied_message": {
      "comment": "Bluetooth permission denied error message",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bluetooth permission was denied. Enable it in System Settings."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Bluetooth 権限が拒否されました。システム設定で有効にしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "蓝牙权限被拒绝。请在系统设置中启用。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bluetooth-Berechtigung wurde verweigert. Aktiviere sie in den Systemeinstellungen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permiso de Bluetooth denegado. Habilítalo en Ajustes del Sistema."
          }
        }
      }
    },
    "ble.permission.required_message": {
      "comment": "Bluetooth permission required explanation",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bluetooth permission is required to scan for BLE devices."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "BLE デバイスをスキャンするには Bluetooth 権限が必要です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "扫描 BLE 设备需要蓝牙权限。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bluetooth-Berechtigung ist erforderlich, um BLE-Geräte zu scannen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se requiere permiso de Bluetooth para escanear dispositivos BLE."
          }
        }
      }
    },
